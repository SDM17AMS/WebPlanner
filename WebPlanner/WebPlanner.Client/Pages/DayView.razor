@page "/"
@inject TaskService TaskService
@using WebPlanner.Shared.DTOs

<h3>Today's Tasks — @DateTime.Today.ToString("dddd, MMM dd")</h3>

@if (tasks == null)
{
    <p>Loading...</p>
}
else if (!tasks.Any())
{
    <p>No tasks for today.</p>
}
else
{
    <ul class="list-group">
        @foreach (var task in tasks)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@task.Title</strong>
                    <div class="text-muted small">@task.Description</div>
                </div>
                <div>
                    <span class="badge bg-@(task.Priority == Priority.High ? "danger" : task.Priority == Priority.Medium ? "warning" : "secondary")">
                        @task.Priority
                    </span>
                    <span class="badge bg-@(task.Status == PlannerTaskStatus.Done ? "success" : "primary")">
                        @task.Status
                    </span>
                    @if (task.DueTime.HasValue)
                    {
                        <span class="badge bg-info">@task.DueTime.Value.ToString("hh\\:mm")</span>
                    }
                </div>
            </li>
        }
    </ul>
}

@code {
    private List<TaskDto>? tasks;

    protected override async Task OnInitializedAsync()
    {
        tasks = await TaskService.GetTasksAsync(DateTime.Today);
    }
}