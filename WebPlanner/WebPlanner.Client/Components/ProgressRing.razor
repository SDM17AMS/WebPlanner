<div class="progress-ring">
    <svg viewBox="0 0 120 120">
        <circle class="progress-ring-bg" cx="60" cy="60" r="50" />
        <circle class="progress-ring-fill" cx="60" cy="60" r="50"
                stroke-dasharray="@Circumference"
                stroke-dashoffset="@Offset" />
    </svg>
    <div class="progress-ring-text">
        <span class="display-6">@Percentage%</span>
        <small class="text-muted">@Completed / @Total</small>
    </div>
</div>

@code {
    [Parameter] public int Completed { get; set; }
    [Parameter] public int Total { get; set; }

    private double Radius => 50;
    private double Circumference => 2 * Math.PI * Radius;
    private double Offset => Circumference * (1 - (double)Percentage / 100);
    private int Percentage => Total == 0 ? 0 : (Completed * 100 / Total);
}